# Public, canonical deployment URL used by metadata, sitemap, and robots.
NEXT_PUBLIC_SITE_URL=https://planner.example.com

# Resend API key. Never expose this with a NEXT_PUBLIC_ prefix.
RESEND_API_KEY=re_replace_me

# Inbox that receives contact-form submissions.
CONTACT_TO_EMAIL=you@example.com

# Sender on a domain verified in Resend.
CONTACT_FROM_EMAIL="MineColonies Planner <planner@updates.example.com>"

# Optional public address shown beside the contact form.
NEXT_PUBLIC_CONTACT_EMAIL=hello@example.com
